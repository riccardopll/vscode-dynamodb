{
  "name": "vscode-dynamodb-explorer",
  "displayName": "DynamoDB Explorer",
  "version": "0.0.1",
  "description": "Browse DynamoDB tables in VS Code",
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "dynamodb",
    "aws",
    "nosql",
    "database",
    "explorer",
    "tables",
    "scan",
    "query"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/riccardopll/vscode-dynamodb.git"
  },
  "license": "MIT",
  "publisher": "riccardopll",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc --noEmit && svelte-check --fail-on-warnings && node scripts/build-extension.mjs && vite build",
    "dev": "node scripts/dev.mjs",
    "lint": "prettier --write . && eslint src --fix",
    "publish": "node scripts/publish-extension.mjs",
    "test": "npm run build && tsc -p tsconfig.test.json && npm run lint && vscode-test"
  },
  "contributes": {
    "configuration": {
      "title": "DynamoDB Explorer",
      "properties": {
        "dynamodb.defaultRegion": {
          "type": "string",
          "default": "us-east-1",
          "description": "Fallback AWS region when the selected profile does not define one."
        },
        "dynamodb.pageSize": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of DynamoDB items to load per request."
        },
        "dynamodb.saveShortcut": {
          "type": "string",
          "default": "Mod+S",
          "description": "Keyboard shortcut for saving staged table edits in the explorer."
        }
      }
    },
    "views": {
      "dynamodb": [
        {
          "id": "dynamodbConnection",
          "name": "Connection",
          "icon": "media/db.svg"
        },
        {
          "id": "dynamodbTables",
          "name": "Tables",
          "icon": "media/db.svg"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dynamodb",
          "title": "DynamoDB",
          "icon": "media/db.svg"
        }
      ]
    }
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.918.0",
    "@aws-sdk/credential-provider-ini": "^3.918.0",
    "@aws-sdk/util-dynamodb": "^3.918.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.1.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "ovsx": "^0.10.6",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "engines": {
    "vscode": "^1.110.0"
  }
}
